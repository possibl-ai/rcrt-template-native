# Copy to .env and fill in. Expo inlines EXPO_PUBLIC_* into the JS bundle at
# build time (the RN equivalent of Vite's VITE_*). For EAS builds, set these in
# eas.json build profiles or as EAS environment secrets instead of committing.

# Required — your RCRT api-gateway URL and the workspace to bind to.
EXPO_PUBLIC_RCRT_API_URL=https://rcrt-api-gateway-xxxx.run.app
EXPO_PUBLIC_RCRT_TENANT_ID=your-workspace-tenant-id

# Key-mode auth (dev / preview): the workspace API key is the token. Leave the
# Firebase vars empty to run in key mode.
EXPO_PUBLIC_RCRT_API_KEY=tk_xxx

# Production auth — Firebase (the TokenProvider seam). When these are set the
# app requires Google sign-in and the Firebase id token becomes the auth token.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
